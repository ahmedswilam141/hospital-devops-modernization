# =============================================================================
# .env.example
# Local development environment variables for docker-compose.yml
#
# USAGE:
#   cp .env.example .env
#   (edit values below if you want something other than the defaults)
#   docker-compose up -d
#
# These variables are read by docker-compose.yml and passed into the
# frontend/backend containers, where PHP reads them via getenv() in
# app/Frontend/connection.php, app/Backend/connection.php, and health.php.
#
# NOTE: These are LOCAL DEVELOPMENT defaults only. In production (EKS), the
# same variable names are injected via Kubernetes ConfigMaps and Secrets
# instead — see k8s/frontend/configmap.yaml and k8s/secrets/external-secrets.yaml.
# Production credentials live in AWS Secrets Manager, never in a .env file.
# =============================================================================

# ── MySQL Database ────────────────────────────────────────────────────────────
# Used by: app/Frontend/connection.php, app/Backend/connection.php, health.php
# In production: DB_HOST becomes the RDS endpoint (see terraform output rds_endpoint)
DB_HOST=mysql
DB_USER=hospital_user
DB_PASS=hospital_pass
DB_NAME=hospital

# Root password for the MySQL container itself (only used at first container startup)
MYSQL_ROOT_PASSWORD=rootpassword

# ── Redis (PHP session storage) ───────────────────────────────────────────────
# Used by: docker/php-sessions.ini, health.php
# In production: REDIS_HOST becomes the ElastiCache endpoint (terraform output redis_endpoint)
REDIS_HOST=redis

# ── S3 (PDF report storage — only used by the backend report upload feature) ──
# Used by: app/Backend/report_upload.php
# Not required for local dev unless you're testing report uploads against real S3.
# In production: comes from terraform output s3_bucket_name
S3_BUCKET=
AWS_REGION=us-east-1

# ── Application environment ───────────────────────────────────────────────────
# Used by docker-compose.yml to tag the running environment. Informational only.
APP_ENV=development
